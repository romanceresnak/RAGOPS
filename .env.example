# Copy: cp .env.example .env  — then fill in values from: terraform output dotenv_block

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# ── Bedrock ───────────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# ── S3 (from: terraform output s3_bucket_name) ────────────────────────────────
S3_BUCKET_NAME=ragops-dev-ragops-xxxx

# ── Neptune (from: terraform output neptune_endpoint) ────────────────────────
NEPTUNE_ENDPOINT=ragops-dev-neptune.cluster-xxxx.us-east-1.neptune.amazonaws.com
NEPTUNE_PORT=8182

# ── IAM (from: terraform output app_role_arn) ─────────────────────────────────
APP_ROLE_ARN=arn:aws:iam::123456789012:role/ragops-dev-app-role

# ── Benchmark settings ────────────────────────────────────────────────────────
BENCHMARK_RUNS=3           # how many times each query is repeated
TOP_K_RAG=3                # chunks retrieved per RAG query
CAG_CACHE_WARMUP=true      # pre-warm cache before benchmark
